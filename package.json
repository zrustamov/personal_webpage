{
  "name": "personal-webpage",
  "version": "1.0.0",
  "private": true,
  "description": "Zaid Rustamov — personal site, deployed via a multi-stage CI/CD pipeline to Azure Static Web Apps.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zrustamov/personal_webpage.git"
  },
  "scripts": {
    "serve": "http-server src -p 8080 -c-1 --silent",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint \"src/**/*.html\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint \"src/**/*.js\"",
    "test:a11y": "pa11y-ci --config tests/accessibility/pa11y-ci.json",
    "test:lighthouse": "lhci autorun --config=tests/lighthouse/lighthouserc.json",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:smoke": "playwright test --config tests/e2e/playwright.config.js --grep @smoke",
    "ci": "npm run lint && npm run test:a11y && npm run test:lighthouse"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "htmlhint": "^1.1.4",
    "http-server": "^14.1.1",
    "pa11y-ci": "^3.1.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
