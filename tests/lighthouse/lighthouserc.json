{
  "ci": {
    "collect": {
      "staticDistDir": "./src",
      "url": [
        "http://localhost/index.html",
        "http://localhost/index-az.html",
        "http://localhost/pages/cv.html",
        "http://localhost/pages/projects.html",
        "http://localhost/pages/publications.html",
        "http://localhost/pages/contact.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "canonical"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
